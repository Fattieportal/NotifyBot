{
  "buildCommand": "cd web-app/frontend && npm install && npm run build",
  "outputDirectory": "web-app/frontend/.next",
  "installCommand": "cd web-app/frontend && npm install",
  "framework": "nextjs",
  "functions": {
    "api/index.py": {
      "runtime": "python3.9"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
